<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="350.0" spacing="20.0" stylesheets="@admin.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project.AddProductController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>
        <Label text="Add New Product" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

        <GridPane hgap="15.0" vgap="15.0">
            <children>
                <Label text="Product ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="idField" promptText="e.g. 103" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="nameField" promptText="e.g. Apple" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Category:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="categoryField" promptText="e.g. Fruits" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Price:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="priceField" promptText="e.g. 15.5" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Quantity:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="quantityField" promptText="e.g. 100" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            </children>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleCancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 8 15;" text="Cancel" />
                <Button mnemonicParsing="false" onAction="#handleSave" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;" text="Save Product" />
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>