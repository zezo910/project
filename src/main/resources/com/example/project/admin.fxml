<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="600.0" prefWidth="900.0" stylesheets="@login.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project.AdminController">
    <left>
        <VBox prefWidth="200.0" spacing="10.0" style="-fx-background-color: #2C3E50;">
            <children>
                <Label text="Admin Panel" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="20.0" top="10.0" />
                    </VBox.margin>
                </Label>
                <Button maxWidth="Infinity" styleClass="sidebar-button" text="Inventory" />
                <Button maxWidth="Infinity" styleClass="sidebar-button" text="Sales Reports" />
                <Region VBox.vgrow="ALWAYS" />
                <Button maxWidth="Infinity" styleClass="logout-button" text="Logout" />
            </children>
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
            </padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" style="-fx-background-color: #F4F7F6;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="searchField" prefWidth="200.0" promptText="Search..." styleClass="input-field" />

                        <Button onAction="#handleEditItem" styleClass="action-button, btn-edit" text="✎ Edit" />
                        <Button onAction="#handleDeleteItem" styleClass="action-button, btn-delete" text="🗑 Delete" />
                        <Button onAction="#handleAddItem" styleClass="action-button, btn-add" text="+ Add Product" />
                    </children>
                </HBox>

                <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idCol" prefWidth="80.0" text="ID" />
                        <TableColumn fx:id="nameCol" prefWidth="150.0" text="Product Name" />
                        <TableColumn fx:id="categoryCol" prefWidth="120.0" text="Category" />
                        <TableColumn fx:id="priceCol" prefWidth="100.0" text="Price" />
                        <TableColumn fx:id="quantityCol" prefWidth="100.0" text="Quantity" />
                        <TableColumn fx:id="actionCol" prefWidth="150.0" text="Actions" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>
